---
import ServicosGrid from '../ServicosGrid.astro';
---

<section id="servicos" class="bio-section" aria-labelledby="servicos-titulo">
	<div class="bio-section-inner">
		<p class="bio-section-label">O que fazemos</p>
		<h2 class="bio-section-titulo" id="servicos-titulo">
			Nossos <span>Serviços</span>
		</h2>
		<p class="bio-section-desc">
			Soluções completas de controle de pragas para residências, estabelecimentos comerciais e
			indústrias.
		</p>

		<ServicosGrid variant="dark" />
	</div>
</section>
