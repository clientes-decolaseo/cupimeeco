---
import { Image } from 'astro:assets';
import site from '../../data/site.json';
import { serviceImages } from '../../lib/service-images';

interface Props {
	variant?: 'dark' | 'light';
}

const { variant = 'dark' } = Astro.props;
---

<div class:list={['bio-servicos-grid', { 'bio-servicos-grid--light': variant === 'light' }]}>
	{
		site.servicos.map((servico) => {
			const imagem = serviceImages[servico.href];
			const imagemAlt = servico.imagemAlt ?? `Serviço de ${servico.nome} — ${site.marca.nome}`;

			return (
				<article class="bio-servico-card">
					{imagem && (
						<a href={servico.href} class="bio-servico-card__media" tabindex="-1" aria-hidden="true">
							<Image
								src={imagem.src}
								alt={imagemAlt}
								width={imagem.width}
								height={imagem.height}
								format="webp"
								quality="mid"
								class="bio-servico-card__img"
								loading="lazy"
								decoding="async"
								sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
								widths={[320, 480, 640]}
							/>
						</a>
					)}
					<div class="bio-servico-card__body">
						<div class="bio-servico-icone" aria-hidden="true">
							{servico.icone}
						</div>
						<h3 class="bio-servico-nome">
							<a href={servico.href}>{servico.nome}</a>
						</h3>
						<p class="bio-servico-desc">{servico.descricao}</p>
						<a href={servico.href} class="bio-servico-link">
							Saiba mais
							<svg
								width="14"
								height="14"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2.5"
								aria-hidden="true"
							>
								<path d="M5 12h14M12 5l7 7-7 7" />
							</svg>
						</a>
					</div>
				</article>
			);
		})
	}
</div>
