---
import { Image } from 'astro:assets';
import site from '../../data/site.json';
import logoImg from '../../assets/cupim-eco-logo.png';

interface Props {
	href?: string;
	current?: boolean;
}

const { href = '/', current = false } = Astro.props;

const Tag = current ? 'span' : 'a';
const linkProps = current ? { 'aria-current': 'page' as const } : { href };
const logoAlt = `${site.marca.nome} — ${site.marca.subtitulo}. ${site.marca.tagline}`;
---

<Tag class="bio-logo" aria-label={`${site.marca.nome} — Página inicial`} {...linkProps}>
	<Image
		src={logoImg}
		alt={logoAlt}
		class="bio-logo-img"
		width={200}
		height={64}
		format="webp"
		quality="mid"
		widths={[200, 400]}
		sizes="200px"
		loading="eager"
		decoding="async"
	/>
</Tag>
