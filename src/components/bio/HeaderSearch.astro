---
---

<button
	type="button"
	class="bio-search-trigger"
	id="site-search-trigger"
	popovertarget="site-search-dialog"
	aria-controls="site-search-dialog"
	aria-expanded="false"
	aria-haspopup="dialog"
>
	<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
		<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
		<path d="M20 20L16.5 16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
	</svg>
	<span class="bio-search-trigger-label">Buscar</span>
</button>

<dialog
	id="site-search-dialog"
	popover="auto"
	class="bio-search-dialog"
	aria-labelledby="site-search-title"
>
	<div class="bio-search-dialog-inner">
		<h2 id="site-search-title" class="bio-search-dialog-title">Buscar no site</h2>
		<form method="get" action="/busca/" class="bio-search-form" role="search">
			<label for="site-search-input" class="visually-hidden">Termo de busca</label>
			<input
				type="search"
				id="site-search-input"
				name="q"
				class="bio-search-input"
				placeholder="Ex.: cupins, dedetização, Osasco…"
				autocomplete="off"
				required
				minlength="2"
				maxlength="80"
			/>
			<div class="bio-search-form-actions">
				<button type="submit" class="bio-search-submit">Buscar</button>
				<button
					type="button"
					class="bio-search-close"
					popovertarget="site-search-dialog"
					popovertargetaction="hide"
				>
					Fechar
				</button>
			</div>
		</form>
	</div>
</dialog>

<script>
	const dialog = document.getElementById('site-search-dialog');
	const trigger = document.getElementById('site-search-trigger');
	const input = document.getElementById('site-search-input');

	if (dialog && trigger && input && 'popover' in HTMLElement.prototype) {
		dialog.addEventListener('toggle', (event) => {
			const isOpen = event.newState === 'open';
			trigger.setAttribute('aria-expanded', String(isOpen));

			if (!isOpen) return;

			input.value = '';
			requestAnimationFrame(() => {
				input.focus({ preventScroll: true });
			});
		});
	}
</script>
