---
import BioLayout from '../layouts/BioLayout.astro';
import LegalDocument from '../components/bio/LegalDocument.astro';
import page from '../data/legal/privacidade.json';
import type { LegalPageData } from '../types/legal';

const legal = page as LegalPageData;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	name: legal.seo.title,
	description: legal.seo.description,
	dateModified: legal.atualizadoEm,
};
---

<BioLayout variant="content" title={legal.seo.title} description={legal.seo.description} jsonLd={jsonLd}>
	<LegalDocument page={legal} />
</BioLayout>
