# Redirects 301: WordPress (/d/) → Astro (raiz)
# Servidor Apache / Plesk

<IfModule mod_rewrite.c>
	RewriteEngine On

	# /d ou /d/ → homepage
	RewriteRule ^d/?$ / [R=301,L]

	# /d/qualquer-caminho → /qualquer-caminho
	RewriteRule ^d/(.+)$ /$1 [R=301,L]

	# Páginas WP vazias (legado)
	RewriteRule ^fotos/?$ / [R=301,L]
	RewriteRule ^biblioteca-da-universo/?$ /blog/ [R=301,L]
	RewriteRule ^glossario-tudo-sobre-descupinizacao/?$ /blog/ [R=301,L]
	RewriteRule ^dedetizacao-de-cupins/?$ /descupinizacao/ [R=301,L]
	RewriteRule ^dedetizadora-de-cupim/?$ /descupinizacao/ [R=301,L]

# BEGIN CUPIM REDIRECTS (npm run audit:seo)
